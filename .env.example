# Keystatic GitHub mode.
#
# Until these are set in production, the site falls back to local file storage
# (open, no login). Set all of them in Vercel (Project > Settings > Environment
# Variables) to switch the live editor to GitHub, which also turns on the login
# gate for the editor and the /help guides.
#
# For local testing of GitHub mode, copy this file to `.env.local` and fill it
# in — but note local dev normally stays on local storage on purpose.

# The repo the editor commits to, as "owner/name" (e.g. "ellieparsonage/portfolio").
NEXT_PUBLIC_KEYSTATIC_GITHUB_REPO=owner/repo

# From the GitHub App you create for Keystatic
# (GitHub > Settings > Developer settings > GitHub Apps > New GitHub App).
# The slug is the last part of the app's URL.
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=your-github-app-slug
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# A long random string that signs the login session.
# Generate one with:  openssl rand -base64 32
KEYSTATIC_SECRET=
